# ============================================================================
# Per-sistant — Personal Assistant Tool — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Neon Postgres ---
# Use the same Neon database as Perfin, or a separate one.
# Format: postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?pgbouncer=true&sslmode=require
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/per_sistant?pgbouncer=true&sslmode=require

# --- Authentication ---
# Set ONE of these to enable login screen. Omit both to run without auth (dev mode).
# SESSION_PASSWORD — full password, shows text input on login
# SESSION_PIN — numeric PIN, shows PIN pad on login
SESSION_PASSWORD=your_secure_password_here
# SESSION_PIN=1234
# SESSION_SECRET=auto_generated_if_not_set

# --- Email (SMTP) ---
# Configure to enable email drafting & scheduled sending.
# Gmail example: use an App Password (not your regular password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=you@gmail.com

# --- Contacts ---
# Optional JSON map of name→email for quick "send to (name)" lookups.
# Example: {"mom":"mom@email.com","boss":"boss@company.com"}
# CONTACTS={}

# --- Perfin Integration ---
# URL of your Perfin instance (for cross-linking navigation).
# PERFIN_URL=https://pers-fin-tracker.onrender.com

# --- Server ---
PORT=3001
